{
  "name": "japan-seasons-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:production": "wrangler deploy --env production",
    "db:migrate": "wrangler d1 execute japan-seasons-db --local --file=src/db/schema.sql",
    "db:seed": "wrangler d1 execute japan-seasons-db --local --file=src/db/seed.sql"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@x402/hono": "^2.9.0",
    "cheerio": "^1.0.0",
    "hono": "^4.12.12"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.2",
    "@cloudflare/workers-types": "^4.20250327.0",
    "@x402/evm": "^2.9.0",
    "@x402/fetch": "^2.9.0",
    "typescript": "^5.8.0",
    "vitest": "~4.1.3",
    "wrangler": "^4.0.0"
  }
}
